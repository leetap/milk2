Set-Content config\boards\shields\milk2\milk2.overlay @'
#include <dt-bindings/zmk/matrix_transform.h>
/ {
    chosen {
        zmk,kscan = &kscan0;
    };
};

/* nice!nano v2: pad "06" => &gpio0 6, pad "08" => &gpio0 8 */
kscan0: kscan {
    compatible = "zmk,kscan-gpio-direct";
    label = "KSCAN-DIRECT";

    /* Order = key order */
    input-gpios = <&gpio0 6 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>,
                  <&gpio0 8 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
};
