Set-Content config\boards\shields\tubetest\tubetest.keymap @'
#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>

/ {
    keymap {
        compatible = "zmk,keymap";

        default_layer {
            bindings = <
                &kp A      &mo 1
            >;
        };

        bt_layer {
            bindings = <
                &bootloader  &bt BT_CLR
            >;
        };
    };
};
'@
